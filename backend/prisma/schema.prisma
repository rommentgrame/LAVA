// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  githubToken   String?
  githubUsername String?
  projects      Project[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages       Page[]
  githubRepo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Page {
  id        String    @id @default(cuid())
  name      String
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  elements  Element[]
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Element {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String   // text, image, video, audio, file, custom
  content   String   // JSON string for rich content
  x         Float    @default(0)
  y         Float    @default(0)
  width     Float    @default(100)
  height    Float    @default(100)
  fromConnections Connection[] @relation("FromConnections")
  toConnections   Connection[] @relation("ToConnections")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Connection {
  id         String @id @default(cuid())
  fromId     String
  toId       String
  from       Element @relation("FromConnections", fields: [fromId], references: [id], onDelete: Cascade)
  to         Element @relation("ToConnections", fields: [toId], references: [id], onDelete: Cascade)
  type       String @default("link")
  createdAt  DateTime @default(now())
}
